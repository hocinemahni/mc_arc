        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# epsilon range (ms^-1)\n",
        "eps = np.logspace(-7, 1, 500)  # 1e-7 .. 10\n",
        "\n",
        "# two delta-t values to show why eps=1e-3 is already in plateau for long gaps\n",
        "dt1 = 56.0        # ms (median for incompact3d)\n",
        "dt2 = 480     # ms = 480 ep95 #10 s (typical phase gap in HPC)\n",
        "\n",
        "E1 = np.exp(-eps * dt1)\n",
        "E2 = np.exp(-eps * dt2)\n",
        "\n",
        "# highlight tested eps values\n",
        "tested_eps = np.array([1.44e-6, 1.16e-5, 2.33e-5, 1e-3, 1e-2, 1e-1, 1, 1000], dtype=float)\n",
        "tested_eps = tested_eps[tested_eps <= eps.max()]  # only those in x-range\n",
        "tested_labels = [\"1.44e-6\",\"1.16e-5\",\"2.33e-5\",\"1e-3\",\"1e-2\",\"1e-1\",\"1\",\"1000\"][:len(tested_eps)]\n",
        "\n",
        "plt.figure(figsize=(8,4.8))\n",
        "plt.plot(eps, E1, linewidth=2, label=\"Δt = 56 ms (median)\")\n",
        "plt.plot(eps, E2, linewidth=2, linestyle=\"--\", label=\"Δt = 480 ms (p95)\")\n",
        "\n",
        "# mark eps=1e-3 and eps=1e-1 and eps=1\n",
        "for v in [1e-3, 1e-2, 1e-1, 1]:\n",
        "    if v >= eps.min() and v <= eps.max():\n",
        "        plt.axvline(v, linewidth=1, linestyle=\":\", alpha=0.9)\n",
        "\n",
        "plt.xscale(\"log\")\n",
        "plt.ylim(-0.05, 1.05)\n",
        "plt.xlabel(\"ε (ms^-1)\")\n",
        "plt.ylabel(\"exp(-ε Δt)\")\n",
        "plt.title(\"Aging factor exp(-εΔt) vs ε for two fixed gaps\")\n",
        "plt.grid(True, which=\"both\", linewidth=0.5)\n",
        "plt.legend(loc=\"best\")\n",
        "plt.subplots_adjust(left=0.12, right=0.98, top=0.88, bottom=0.14)\n",
        "out = \"incompact3d.png\"\n",
        "plt.savefig(out, dpi=200)\n",
        "plt.show()\n",
        "\n",
        "out"
      ],
